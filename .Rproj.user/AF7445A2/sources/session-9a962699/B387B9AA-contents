We will fetch population data for all our DeSO codes for year 2024 in
different age groups.

```{r}
# SCB endpoint + metadata
url  <- "https://api.scb.se/OV0104/v1/doris/sv/ssd/START/BE/BE0101/BE0101Y/FolkmDesoAldKon"
meta <- pxweb_get(url)

# Build a fast look-up for variables by code
vars_by_code <- setNames(meta$variables, purrr::map_chr(meta$variables, "code"))
vals <- function(code) vars_by_code[[code]]$values

# SCB DeSO Region values have "_DeSO2025" suffix, so we need to append it
region_vals <- intersect(paste0(deso_codes, "_DeSO2025"), vals("Region"))

# Query parameters
year        <- "2024"
kon_tot     <- "1+2"        # both sexes
contents_fm <- "000007Y7"   # Folkmängd measure

# SCB age codes formatting
age_to_col <- function(ac, prefix = "pop") {
  ac <- as.character(ac)
  if (ac == "-4")  return(paste0(prefix, "_0_4"))
  if (ac == "80-") return(paste0(prefix, "_80p"))
  paste0(prefix, "_", gsub("-", "_", ac))
}

# Function to fetch multiple ages in one request
fetch_ages_wide <- function(age_codes, chunk_size = 300, prefix = "pop") {
  age_codes <- intersect(as.character(age_codes), vals("Alder"))
  chunks <- split(region_vals, ceiling(seq_along(region_vals) / chunk_size))
  
  fetch_chunk <- function(reg_chunk) {
    pxq <- pxweb_query(list(
      Region       = as.character(unname(reg_chunk)),
      Alder        = age_codes,
      Kon          = kon_tot,
      ContentsCode = contents_fm,
      Tid          = year))
    
    df <- suppressWarnings(
      pxweb_get_data(
        url = url,
        query = pxq,
        column.name.type = "code",
        variable.value.type = "code"))
    
    df |>
      transmute(
        desokod = sub("_DeSO2025$", "", Region),
        Tid     = as.character(Tid),
        Alder   = as.character(Alder),
        value   = suppressWarnings(as.numeric(.data[[contents_fm]])))
}
  
  long <- purrr::map_dfr(chunks, fetch_chunk)
  
  long |>
    mutate(col = vapply(Alder, age_to_col, character(1), prefix = prefix)) |>
    select(-Alder) |>
    tidyr::pivot_wider(names_from = col, values_from = value)
}

# Age categories
kids_codes    <- c("-4", "5-9", "10-14", "15-19")
working_codes <- c("20-24","25-29","30-34","35-39","40-44","45-49","50-54","55-59","60-64")
elderly_codes <- c("65-69", "70-74", "75-79", "80-")
needed_ages <- c(kids_codes, working_codes, elderly_codes)

# Fetch and join
df_groups <- fetch_ages_wide(needed_ages, chunk_size = 300, prefix = "pop")

deso <- deso |>
  left_join(df_groups, by = "desokod") |>
  mutate(
    kids_0_19 = rowSums(across(c(pop_0_4, pop_5_9, pop_10_14, pop_15_19)), na.rm = TRUE),
    working_20_64 = rowSums(across(c(
      pop_20_24, pop_25_29, pop_30_34, pop_35_39, pop_40_44,
      pop_45_49, pop_50_54, pop_55_59, pop_60_64
    )), na.rm = TRUE),
    elderly_65p = rowSums(across(c(pop_65_69, pop_70_74, pop_75_79, pop_80p)), na.rm = TRUE)
  )
deso
```

Ok, so this is our population data for different DeSO in Uppsala grouped
per age category. We can now proceed to experiment with some heat
metrics.

### Heat metrics.

Here we can extract all hot pixels above an arbitrary threshold and do
some stats, like their coverage and fraction to get a feeling what our
results can tell us.

```{r}
library(exactextractr)
pred <- rast("predicted_highres.tif")
hot_thr   <- 30 # °C threshold               
cell_area <- prod(res(pred)) # m² per pixel

# Exposure intensity: 95th percentile LST
# For each polygon in DeSo, this extracts raster values inside the polygon, ignores NA cells, calculates the 95th percentile of temperature values and stores the results. In other words it gives a measure of heat intensity within each polygon. The percentile is based only on extracted cell values, not weighted by how much of each cell lies inside the polygon.
deso$lst_p95 <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    v <- values[!is.na(values)]
    if (length(v) == 0) return(NA_real_)
    as.numeric(quantile(v, probs = 0.95, na.rm = TRUE, type = 7))
  })

# Mean LST of "hot" cells only >= threshold
# For each polygon, this command keeps only cells where temperature is at least 30 °C, returns NA if there are no such cells and calculates the coverage-weighted mean of those hot-cell temperatures. The results tell you, within the hot parts of a polygon only, what the average hot temperature is.
deso$lst_mean_hot <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    ok <- !is.na(values) & values >= hot_thr
    if (!any(ok)) return(NA_real_)
    # coverage_fraction-weighted mean
    sum(values[ok] * coverage_fraction[ok], na.rm = TRUE) /
      sum(coverage_fraction[ok], na.rm = TRUE)
  })

# Exposure extent, fraction of covered area that is hot >= threshold
# For each polygon, we find cells with non-missing values and temperature at least 30 °, sum their coverage fractions and multiplie by cell area. This gives us the hot area in square meters inside the polygon.
deso$hot_area_m2 <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    sum(coverage_fraction[!is.na(values) & values >= hot_thr], na.rm = TRUE) * cell_area
  })

# Finally we sum the coverage fractions of all non-NA raster cells inside the polygon and multiply them by cell area. This is the area of the polygon that is actually covered by valid raster data. That is important because some parts of a polygon may fall outside the raster or on NA cells.
deso$covered_area_m2 <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    sum(coverage_fraction[!is.na(values)], na.rm = TRUE) * cell_area
  })

# Fraction and percent of covered area that is hot
# This chunk adds two new columns:
# hot_frac_cov: proportion of raster-covered area that is hot
# hot_percent_cov: the same value in percent, rounded to 2 decimals
# It gives the extent of heat exposure within the valid raster-covered part of each polygon.
deso <- deso |>
  mutate(
    hot_frac_cov     = ifelse(covered_area_m2 > 0, hot_area_m2 / covered_area_m2, NA_real_),
    hot_percent_cov  = round(100 * hot_frac_cov, 2))

# And then we print the results
deso
```

After running this, each DeSo polygon gets:

1.  lst_p95 → how high temperatures get near the upper end
2.  lst_mean_hot → average temperature of only the hot areas
3.  hot_area_m2 → how much area is hot
4.  covered_area_m2 → how much area has valid raster data
5.  hot_frac_cov / hot_percent_cov → what share of valid area is hot

Ok. Let's experiment with municipality heat exposure. Where in the city
do we have both high heat and many heat-sensitive people?

```{r}
# Simple heat vulnerability index
(deso_hvi <- deso %>%
    # Start from DeSo and create new variables
  mutate(
    # Sums the three age groups to get the total population in each area
    total_pop     = kids_0_19 + working_20_64 + elderly_65p,
    # Share of elderly people
    elderly_share = ifelse(total_pop > 0, elderly_65p / total_pop, NA_real_),
    # Exposure index: combination of intensity + extent
    # Here we assume that heat intensity and hot-area extent matter equally
    # lst_p95 = how intense the heat is
    # hot_percent_cov = how much of the area is hot
    E = as.numeric(scale(lst_p95)[,1] + scale(hot_percent_cov)[,1]),
    # Sensitivity: elderly share
    S = as.numeric(scale(elderly_share)[,1]),
    # HVI
    HVI = as.numeric(scale(E)[,1] + scale(S)[,1])))
```

scale() standardizes a variable using:

$$
(value - mean) / sd
$$

So after scaling 0 means average, positive means above average, negative
means below average.

Exposure is high when an area is both hotter than average and has a
larger hot area than average. Example:

1.  Area A: high lst_p95, high hot_percent_cov → high E
2.  Area B: low on both → low E

The same goes for Sensitivity index. Here we standardize elderly share:

1.  positive S = more elderly than average
2.  negative S = less elderly than average

And finally HVI. Here we scale E and S again and sum them up. So the
final index is:

$$
HVI = standardized exposure + standardized sensitivity
$$

1.  High heat exposure and high elderly share → high HVI.
2.  Low exposure or low elderly share → lower HVI.

