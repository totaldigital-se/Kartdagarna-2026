ax[1].imshow(ds['NDBI'], vmin=-1, vmax=1, cmap='RdBu');   ax[1].set_title('NDBI')
ax[2].imshow(ds['MNDWI'], vmin=-1, vmax=1, cmap='BrBG');  ax[2].set_title('MNDWI')

[a.axis('off') for a in ax]
