## Phase 3: Apply the trained model at a higher resolution.

Now we know the relationship between the different factors and LST, so we can load in higher resolution data and predict at a finer grid resolution.

We load higher-res Sentinel-2 + DSM, compute the same features, then predict.

```{python}
# Load hi-res predictors and force everything onto the S2 grid
s2  = rxr.open_rasterio("modelling_data/target_resolution/S2_composite.tif", masked=True).assign_coords(band=["B","G","R","NIR","SWIR1","SWIR2"]).to_dataset("band")
dsm = rxr.open_rasterio("modelling_data/target_resolution/DSM.tif", masked=True).isel(band=0, drop=True)
ds_hi = xr.merge([s2, xr.Dataset({"DSM": dsm})]).rio.reproject_match(s2["B"])

# Scale kernel so neighborhood (meters) matches training (e.g., 9px @ 1000 m)
def scaled_kernel_size(train_res_m: float, pred_res_m: float, train_kernel: int) -> int:
    k = int(round(train_kernel * (train_res_m / pred_res_m)))
    return max(1, k + (k % 2 == 0))  # odd + >=1

train_res_m = 1000.0
pred_res_m  = abs(float(ds_hi["B"].rio.resolution()[0]))
k9 = scaled_kernel_size(train_res_m, pred_res_m, 9)
```

### Recompute indices + terrain features on the high-res grid.

These must match the training feature definitions.

```{python}
# Indices
ds_hi["NDVI"]  = (ds_hi["NIR"]   - ds_hi["R"])     / (ds_hi["NIR"]   + ds_hi["R"])
ds_hi["NDBI"]  = (ds_hi["SWIR1"] - ds_hi["NIR"])   / (ds_hi["SWIR1"] + ds_hi["NIR"])
ds_hi["MNDWI"] = (ds_hi["G"]     - ds_hi["SWIR1"]) / (ds_hi["G"]     + ds_hi["SWIR1"])

# DEM/DSM derivatives
slope, asp = slope_aspect(ds_hi["DSM"])
ds_hi["slope_dsm"]  = slope
ds_hi["aspect_sin"] = np.sin(np.deg2rad(asp))
ds_hi["aspect_cos"] = np.cos(np.deg2rad(asp))

# Neighborhood means (scaled kernel)
ds_hi["ndvi_mean9"]  = focal_mean_nan(ds_hi["NDVI"],  k9)
ds_hi["mndwi_mean9"] = focal_mean_nan(ds_hi["MNDWI"], k9)
ds_hi["dsm_mean9"]   = focal_mean_nan(ds_hi["DSM"],   k9)
```

### Add coordinate predictors and run high-res prediction.

Function to predict.

```{python}
def predict_to_raster(ds_pred: xr.Dataset, model, ref: xr.DataArray, out_tif: str):
    Xp = pd.DataFrame({f: ds_pred[f].values.ravel() for f in model.feature_names_in_})
    ok = np.isfinite(Xp.to_numpy()).all(axis=1)

    yhat = np.full(len(Xp), np.nan, np.float32)
    yhat[ok] = model.predict(Xp.loc[ok]).astype(np.float32)

    da = xr.DataArray(yhat.reshape(ref.shape), dims=ref.dims, coords=ref.coords, name="prediction") \
           .rio.write_crs(ref.rio.crs).rio.write_transform(ref.rio.transform())
    da.rio.to_raster(out_tif, compress="deflate", tiled=True, blockxsize=256, blockysize=256)
    return da
```

