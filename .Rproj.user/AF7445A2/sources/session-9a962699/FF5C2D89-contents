    pop_over70  = sum(value[age >= 70], na.rm = TRUE),
    pop_under10 = sum(value[age <= 10], na.rm = TRUE),
    share_over70  = pop_over70 / pop_total,
    share_under10 = pop_under10 / pop_total,
    .groups = "drop"
  ))
```

