```{r}
# Hot intensity, mean exceedance (°C) among hot cells only
deso$hot_exceed_mean <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    ok <- !is.na(values) & values >= hot_thr
    if (!any(ok)) return(0)  # define 0 if no hot cells
    w <- coverage_fraction[ok]
    v <- values[ok] - hot_thr
    sum(v * w, na.rm = TRUE) / sum(w, na.rm = TRUE)
  }
)

# Hot burden (°C * m²) = area-weighted exceedance
deso$hot_exceed_burden <- exact_extract(
  pred, deso,
  function(values, coverage_fraction) {
    ok <- !is.na(values) & values >= hot_thr
    if (!any(ok)) return(0)
    sum((values[ok] - hot_thr) * coverage_fraction[ok], na.rm = TRUE) * cell_area
  }
)

deso <- deso |>
    mutate(
      elderly_exposure_proxy  = pop_over70  * hot_frac_cov,
      children_exposure_proxy = pop_under10 * hot_frac_cov)

(deso <- deso |>
  mutate(
    elderly_score = elderly_exposure_proxy * hot_exceed_mean,
    children_score = children_exposure_proxy * hot_exceed_mean))
```

