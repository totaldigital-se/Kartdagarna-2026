s2    = rxr.open_rasterio("modelling_data/original_resolution/S2_composite.tif", masked=True).assign_coords(band=["B","G","R","NIR","SWIR1","SWIR2"])

dsm   = rxr.open_rasterio("modelling_data/original_resolution/DSM.tif", masked=True).assign_coords(band=["DSM"])

ds_modis = modis.to_dataset(dim="band")
ds_s2 = s2.to_dataset(dim="band")
ds_dsm = dsm.to_dataset(dim="band")

# Combine into one dataset
ds = xr.merge([ds_modis, ds_s2, ds_dsm])
```

