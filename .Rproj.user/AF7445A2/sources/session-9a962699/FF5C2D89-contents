read_wfs_sf <- function(typename, cql_filter = NULL, srs = 3006) {
  base <- paste0(
    wfs,
    "?service=WFS&version=2.0.0&request=GetFeature",
    "&typeNames=", URLencode(typename, reserved = TRUE),
    "&outputFormat=application/json",
