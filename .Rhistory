deso
# Simple heat vulnerability index
(deso_hvi <- deso %>%
mutate(
total_pop     = kids_0_19 + working_20_64 + elderly_65p,
elderly_share = ifelse(total_pop > 0, elderly_65p / total_pop, NA_real_),
# Exposure index: combination of intensity + extent
E = as.numeric(scale(lst_p95)[,1] + scale(hot_percent_cov)[,1]),
# Sensitivity: elderly share
S = as.numeric(scale(elderly_share)[,1]),
# HVI: multiplicative co-location
HVI = as.numeric(scale(E)[,1] * scale(S)[,1])))
# CRS for plotting in interactive html
deso_hvi <- deso_hvi |> st_transform(4326)
# Palette
pal <- colorNumeric("viridis", domain = deso_hvi$HVI, na.color = "transparent")
# Map
(m <- leaflet(deso_hvi) %>%
addProviderTiles("CartoDB.Positron") %>%
addPolygons(
color = "#444444", weight = 0.4,
fillOpacity = 0.5,
fillColor = ~pal(HVI),
popup = ~paste0(
"<b>DeSO:</b> ", desokod,
"<br><b>Kommun:</b> ", kommunnamn,
"<br><b>HVI:</b> ", round(HVI, 2),
"<br><b>LST p95:</b> ", round(lst_p95, 2), "°C",
"<br><b>Hot area:</b> ", round(hot_percent_cov, 1), "%",
"<br><b>Elderly share:</b> ", round(100 * elderly_share, 1), "%"
)
) %>%
addLegend("bottomright", pal = pal, values = ~HVI, title = "Heat Vulnerability Index"))
